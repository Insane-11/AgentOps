# Database
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops
DATABASE_URL_SYNC=postgresql://agentops:agentops@localhost:5432/agentops

# JWT
JWT_SECRET=change-me-in-production

# Ollama (LLM) - runs locally, completely free
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LangFuse (optional, self-hosted observability — open source LangSmith alternative)
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=http://localhost:3000

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Server
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
APP_URL=http://localhost:5174
